SELECT 
    s.order_id,
    SUM(s.quantity) AS total_items_in_order,
    -- Calculate total money for the order
    SUM(s.quantity * i.price) AS total_sales_amount,
    -- Calculate average money spent per line item in the order
    AVG(s.quantity * i.price) AS avg_sales_amount_per_item
FROM sales s
JOIN inventories i ON s.product_id = i.product_id
GROUP BY s.order_id;
